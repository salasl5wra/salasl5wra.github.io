<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Inspecciones — Portal EHS · WRA</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600;700;800&family=Source+Sans+3:wght@400;500;600;700&family=Roboto+Mono:wght@500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --navy-deep: #00264d;
    --navy: #003b71;
    --blue: #009cde;
    --blue-dark: #0078ad;
    --ink: #1a1f29;
    --gray-700: #4a5160;
    --gray-400: #8891a0;
    --gray-200: #e2e6eb;
    --gray-100: #f1f3f6;
    --paper: #fbfbfc;
    --safe-green: #2f8f5b;
    --amber: #b8860b;
    --red: #c0392b;
    --line: rgba(255,255,255,0.14);

    --font-display: 'Archivo', sans-serif;
    --font-body: 'Source Sans 3', sans-serif;
    --font-mono: 'Roboto Mono', monospace;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    font-family: var(--font-body);
    color: var(--ink);
    background: var(--paper);
    -webkit-font-smoothing: antialiased;
  }

  a { color: inherit; }

  /* ===== Utility bar ===== */
  .utility-bar {
    background: var(--navy-deep);
    color: #c9d6e6;
    font-size: 0.78rem;
    padding: 7px 40px;
    display: flex;
    justify-content: flex-end;
    gap: 24px;
    letter-spacing: 0.2px;
  }
  .utility-bar a { text-decoration: none; color: #c9d6e6; opacity: 0.9; transition: opacity 0.15s; }
  .utility-bar a:hover { opacity: 1; color: #ffffff; }
  .utility-bar .divider { opacity: 0.3; }

  /* ===== Main nav ===== */
  .main-nav {
    background: var(--navy);
    padding: 0 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
    border-bottom: 3px solid var(--blue);
  }

  .brand { display: flex; align-items: center; gap: 14px; text-decoration: none; }

  .brand-mark {
    width: 38px; height: 38px;
    border: 2px solid var(--blue);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display); font-weight: 800;
    color: #ffffff; font-size: 0.95rem; letter-spacing: 0.5px;
  }

  .brand-text { display: flex; flex-direction: column; line-height: 1.15; }
  .brand-text .org { font-family: var(--font-display); font-weight: 700; color: #ffffff; font-size: 1.05rem; letter-spacing: 0.5px; }
  .brand-text .division { font-size: 0.7rem; color: #9fc4e6; letter-spacing: 1.2px; text-transform: uppercase; font-weight: 600; }

  .nav-links { display: flex; gap: 36px; align-items: center; }
  .nav-links a {
    text-decoration: none; color: #dbe7f3; font-size: 0.88rem; font-weight: 500;
    letter-spacing: 0.2px; position: relative; padding: 8px 0; transition: color 0.15s;
  }
  .nav-links a:hover { color: #ffffff; }
  .nav-links a.active { color: #ffffff; }
  .nav-links a.active::after {
    content: ''; position: absolute; bottom: -3px; left: 0; right: 0; height: 2px; background: var(--blue);
  }

  /* ===== Page header ===== */
  .page-header {
    background: linear-gradient(165deg, var(--navy-deep) 0%, var(--navy) 100%);
    color: #ffffff;
    padding: 40px 40px 34px;
  }

  .breadcrumb {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.5px;
    color: #8fb8da;
    margin-bottom: 14px;
  }
  .breadcrumb a { color: #8fb8da; text-decoration: none; }
  .breadcrumb a:hover { color: #ffffff; }

  .page-header-row {
    max-width: 1240px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 30px;
  }

  .page-header h1 {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 8px;
    letter-spacing: -0.3px;
  }

  .page-header p {
    color: #bcd2e6;
    font-size: 0.95rem;
    margin: 0;
    max-width: 560px;
  }

  .btn {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.88rem;
    padding: 12px 24px;
    border-radius: 2px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    letter-spacing: 0.2px;
    white-space: nowrap;
    cursor: pointer;
    border: none;
  }

  .btn-primary { background: var(--blue); color: #ffffff; border: 1px solid var(--blue); }
  .btn-primary:hover { background: var(--blue-dark); border-color: var(--blue-dark); }

  .btn-outline-light { background: transparent; color: #ffffff; border: 1px solid rgba(255,255,255,0.35); }
  .btn-outline-light:hover { border-color: #ffffff; background: rgba(255,255,255,0.06); }

  /* ===== Container ===== */
  .container { max-width: 1240px; margin: 0 auto; padding: 0 40px; }

  /* ===== Summary cards ===== */
  .summary-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--gray-200);
    border: 1px solid var(--gray-200);
    margin-top: -1px;
    transform: translateY(-26px);
  }

  .summary-card {
    background: #ffffff;
    padding: 22px 24px;
    position: relative;
  }

  .summary-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 3px;
  }

  .summary-card.tone-green::before { background: var(--safe-green); }
  .summary-card.tone-amber::before { background: var(--amber); }
  .summary-card.tone-red::before { background: var(--red); }
  .summary-card.tone-navy::before { background: var(--navy); }

  .summary-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--gray-400);
    margin-bottom: 10px;
  }

  .summary-value {
    font-family: var(--font-mono);
    font-size: 2.1rem;
    font-weight: 600;
    color: var(--ink);
    line-height: 1;
  }

  .summary-sub { font-size: 0.78rem; color: var(--gray-400); margin-top: 6px; }

  /* ===== Section ===== */
  .section { padding: 10px 0 70px; }

  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 26px;
    border-bottom: 1px solid var(--gray-200);
    padding-bottom: 18px;
  }

  .section-head h2 {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--navy);
    margin: 0;
    letter-spacing: -0.2px;
  }

  .section-tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--gray-400);
  }

  /* ===== Filter bar ===== */
  .filter-bar {
    display: flex;
    gap: 10px;
    margin-bottom: 22px;
    flex-wrap: wrap;
  }

  .filter-chip {
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    padding: 8px 18px;
    border: 1px solid var(--gray-200);
    background: #ffffff;
    color: var(--gray-700);
    cursor: pointer;
    transition: all 0.15s;
    border-radius: 2px;
  }

  .filter-chip.active { background: var(--navy); color: #ffffff; border-color: var(--navy); }
  .filter-chip:hover:not(.active) { border-color: var(--blue); color: var(--navy); }

  .filter-search {
    margin-left: auto;
    display: flex;
    align-items: center;
    border: 1px solid var(--gray-200);
    padding: 0 14px;
    background: #ffffff;
    min-width: 240px;
  }

  .filter-search svg { width: 16px; height: 16px; color: var(--gray-400); flex-shrink: 0; }
  .filter-search input {
    border: none; outline: none; padding: 9px 10px; font-family: var(--font-body);
    font-size: 0.85rem; width: 100%; color: var(--ink);
  }

  /* ===== Table ===== */
  .table-wrap {
    border: 1px solid var(--gray-200);
    overflow-x: auto;
  }

  table { width: 100%; border-collapse: collapse; min-width: 760px; }

  thead tr { background: var(--gray-100); }

  th {
    text-align: left;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: var(--gray-700);
    padding: 13px 18px;
    border-bottom: 1px solid var(--gray-200);
    font-weight: 600;
    white-space: nowrap;
  }

  td {
    padding: 16px 18px;
    border-bottom: 1px solid var(--gray-200);
    font-size: 0.88rem;
    color: var(--ink);
    vertical-align: middle;
  }

  tbody tr:last-child td { border-bottom: none; }
  tbody tr:hover { background: var(--gray-100); }

  .cat-pill {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--navy);
  }

  .cat-pill svg { width: 16px; height: 16px; color: var(--blue); }

  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.3px;
    padding: 4px 10px;
    text-transform: uppercase;
  }

  .status-pill .dot { width: 6px; height: 6px; border-radius: 50%; }

  .status-completa { background: rgba(47,143,91,0.1); color: var(--safe-green); }
  .status-completa .dot { background: var(--safe-green); }

  .status-pendiente { background: rgba(184,134,11,0.1); color: var(--amber); }
  .status-pendiente .dot { background: var(--amber); }

  .status-hallazgos { background: rgba(192,57,43,0.1); color: var(--red); }
  .status-hallazgos .dot { background: var(--red); }

  .row-link {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--blue);
    text-decoration: none;
  }
  .row-link:hover { text-decoration: underline; }

  .table-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 18px;
    background: var(--gray-100);
    font-size: 0.78rem;
    color: var(--gray-400);
  }

  /* ===== New inspection / checklist section ===== */
  .new-inspection {
    border: 1px solid var(--gray-200);
    background: #ffffff;
  }

  .new-inspection-head {
    padding: 26px 28px;
    border-bottom: 1px solid var(--gray-200);
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 20px;
  }

  .new-inspection-head h3 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--navy);
    margin: 0 0 6px;
  }

  .new-inspection-head p {
    font-size: 0.85rem;
    color: var(--gray-700);
    margin: 0;
    max-width: 480px;
  }

  .type-selector {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--gray-200);
  }

  .type-option {
    background: #ffffff;
    padding: 22px 20px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 14px;
    transition: background 0.15s;
    border: none;
    text-align: left;
    font-family: var(--font-body);
  }

  .type-option:hover { background: var(--gray-100); }
  .type-option.selected { background: #eef7fd; }
  .type-option.selected .type-icon { background: var(--blue); color: #ffffff; }

  .type-icon {
    width: 40px; height: 40px;
    flex-shrink: 0;
    border-radius: 50%;
    background: var(--gray-100);
    color: var(--navy);
    display: flex; align-items: center; justify-content: center;
    transition: all 0.15s;
  }

  .type-icon svg { width: 20px; height: 20px; }

  .type-name { font-size: 0.92rem; font-weight: 700; color: var(--ink); }
  .type-meta { font-size: 0.76rem; color: var(--gray-400); margin-top: 2px; }

  .checklist-panel { padding: 28px; }

  .checklist-meta-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 18px;
    margin-bottom: 26px;
  }

  .field-group label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: var(--gray-400);
    margin-bottom: 7px;
  }

  .field-group select, .field-group input {
    width: 100%;
    border: 1px solid var(--gray-200);
    padding: 10px 12px;
    font-family: var(--font-body);
    font-size: 0.88rem;
    color: var(--ink);
    background: #ffffff;
  }

  .checklist-items { display: flex; flex-direction: column; gap: 1px; background: var(--gray-200); border: 1px solid var(--gray-200); }

  .checklist-item {
    background: #ffffff;
    padding: 16px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
  }

  .checklist-item-text { font-size: 0.9rem; color: var(--ink); flex: 1; }
  .checklist-item-num { font-family: var(--font-mono); color: var(--gray-400); font-size: 0.78rem; margin-right: 10px; }

  .checklist-options { display: flex; gap: 8px; flex-shrink: 0; }

  .opt-btn {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    padding: 7px 16px;
    border: 1px solid var(--gray-200);
    background: #ffffff;
    color: var(--gray-700);
    cursor: pointer;
    border-radius: 2px;
    transition: all 0.15s;
  }

  .opt-btn.ok.selected { background: var(--safe-green); color: #ffffff; border-color: var(--safe-green); }
  .opt-btn.fail.selected { background: var(--red); color: #ffffff; border-color: var(--red); }
  .opt-btn:hover:not(.selected) { border-color: var(--blue); }

  .checklist-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 22px;
    padding-top: 20px;
    border-top: 1px solid var(--gray-200);
  }

  .checklist-progress { font-size: 0.82rem; color: var(--gray-400); }
  .checklist-progress strong { color: var(--ink); }

  .footer-strip {
    background: var(--navy-deep);
    padding: 18px 40px;
    text-align: center;
    font-size: 0.74rem;
    color: #7e93ab;
    letter-spacing: 0.3px;
  }

  @media (max-width: 980px) {
    .page-header, .main-nav { padding-left: 24px; padding-right: 24px; }
    .nav-links { display: none; }
    .summary-row { grid-template-columns: 1fr 1fr; transform: translateY(-16px); }
    .container { padding: 0 24px; }
    .page-header-row { flex-direction: column; align-items: flex-start; }
    .type-selector { grid-template-columns: 1fr; }
    .checklist-meta-row { grid-template-columns: 1fr; }
    .filter-search { margin-left: 0; width: 100%; }
  }
</style>
</head>

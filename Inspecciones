  <script>
    // ---- Filtro de tabla por categoría ----
    const chips = document.querySelectorAll('.filter-chip');
    const rows = document.querySelectorAll('#inspectionTable tbody tr');
    const searchInput = document.getElementById('searchInput');

    function applyFilters() {
      const activeChip = document.querySelector('.filter-chip.active').dataset.filter;
      const searchTerm = searchInput.value.toLowerCase();

      rows.forEach(row => {
        const matchesCategory = activeChip === 'todas' || row.dataset.cat === activeChip;
        const matchesSearch = row.textContent.toLowerCase().includes(searchTerm);
        row.style.display = (matchesCategory && matchesSearch) ? '' : 'none';
      });
    }

    chips.forEach(chip => {
      chip.addEventListener('click', () => {
        chips.forEach(c => c.classList.remove('active'));
        chip.classList.add('active');
        applyFilters();
      });
    });

    searchInput.addEventListener('input', applyFilters);

    // ---- Checklists por categoría ----
    const checklistData = {
      extintores: [
        "Extintor visible y sin obstrucciones",
        "Señalización correcta y legible",
        "Presión dentro del rango (aguja en zona verde)",
        "Sello de seguridad intacto",
        "Manguera y boquilla en buen estado",
        "Soporte o gabinete en buen estado",
        "Etiqueta de última recarga vigente",
        "Acceso libre en un radio de 1 metro"
      ],
      hidrantes: [
        "Hidrante visible y sin obstrucciones",
        "Tapa y rosca en buen estado, sin fugas",
        "Presión de línea dentro de parámetro",
        "Señalización y pintura reglamentaria",
        "Llave de paso opera correctamente",
        "Acceso vehicular despejado"
      ],
      confinados: [
        "Permiso de entrada vigente y firmado",
        "Medición de atmósfera realizada (O2, gases)",
        "Ventilación forzada disponible y operando",
        "Equipo de rescate disponible en sitio",
        "Vigía asignado y capacitado presente",
        "Sistema de comunicación funcionando",
        "Equipo de protección personal verificado",
        "Punto de anclaje y línea de vida inspeccionados",
        "Iluminación adecuada dentro del espacio",
        "Plan de emergencia revisado con el equipo"
      ]
    };

    const typeButtons = document.querySelectorAll('.type-option');
    const checklistContainer = document.getElementById('checklistItems');
    const progressCount = document.getElementById('progressCount');
    const progressTotal = document.getElementById('progressTotal');

    function renderChecklist(type) {
      const items = checklistData[type];
      checklistContainer.innerHTML = '';
      progressTotal.textContent = items.length;
      progressCount.textContent = '0';

      items.forEach((text, i) => {
        const item = document.createElement('div');
        item.className = 'checklist-item';
        item.innerHTML = `
          <div class="checklist-item-text"><span class="checklist-item-num">${String(i + 1).padStart(2, '0')}</span>${text}</div>
          <div class="checklist-options">
            <button class="opt-btn ok" type="button">Cumple</button>
            <button class="opt-btn fail" type="button">No cumple</button>
          </div>
        `;
        checklistContainer.appendChild(item);
      });
      updateProgress();
    }

    function updateProgress() {
      const total = checklistContainer.querySelectorAll('.checklist-item').length;
      const answered = checklistContainer.querySelectorAll('.opt-btn.selected');
      // Each item counts once if either option is selected
      const answeredItems = new Set();
      answered.forEach(btn => answeredItems.add(btn.closest('.checklist-item')));
      progressCount.textContent = answeredItems.size;
      progressTotal.textContent = total;
    }

    checklistContainer.addEventListener('click', (e) => {
      const btn = e.target.closest('.opt-btn');
      if (!btn) return;
      const siblings = btn.parentElement.querySelectorAll('.opt-btn');
      siblings.forEach(s => s.classList.remove('selected'));
      btn.classList.add('selected');
      updateProgress();
    });

    typeButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        typeButtons.forEach(b => b.classList.remove('selected'));
        btn.classList.add('selected');
        renderChecklist(btn.dataset.type);
      });
    });

    // Render inicial
    renderChecklist('extintores');
  </script>

